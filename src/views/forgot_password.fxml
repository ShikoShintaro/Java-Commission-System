<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<StackPane fx:id="liquidPane"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.ForgotPasswordController"
           stylesheets="@forgot.css"
           prefWidth="950" prefHeight="600">

    <!-- Liquid animated gradient background -->
    <Rectangle fx:id="liquidBackground"
               width="950" height="600"
               styleClass="animated-background"/>

    <!-- Subtle overlay for contrast -->
    <Rectangle fx:id="liquidOverlay"
               width="950" height="600"
               fill="rgba(0,0,0,0.25)"/>

    <HBox alignment="CENTER" spacing="0" prefWidth="950" prefHeight="600">
        <VBox fx:id="formBox"
              alignment="CENTER"
              spacing="15"
              styleClass="form-container"
              prefWidth="400"
              maxWidth="400">

            <Label text="Forgot Password" styleClass="form-title"/>

            <!-- Step 1: Enter username -->
            <VBox fx:id="step1Box" styleClass="step-box" visible="true" managed="true" spacing="10">
                <TextField fx:id="usernameField" promptText="Username" styleClass="input-field"/>
                <Label fx:id="step1Status" styleClass="error-label"/>
                <Button text="Next" onAction="#handleStep1Next" styleClass="submit-button"/>
            </VBox>

            <!-- Step 2: Security question + OTP -->
            <VBox fx:id="step2Box" styleClass="step-box" visible="false" managed="false" spacing="10">
                <Label fx:id="questionLabel" text="" styleClass="question-label"/>
                <TextField fx:id="answerField" promptText="Your Answer" styleClass="input-field"/>
                <TextField fx:id="otpField" promptText="Enter OTP (123456)" styleClass="input-field"/>
                <Label fx:id="step2Status" styleClass="error-label"/>
                <Button text="Next" onAction="#handleStep2Next" styleClass="submit-button"/>
                <Button text="Back" onAction="#handleBack" styleClass="back-button"/>
            </VBox>

            <!-- Step 3: Reset password -->
            <VBox fx:id="step3Box" styleClass="step-box" visible="false" managed="false" spacing="10">
                <PasswordField fx:id="newPasswordField" promptText="New Password" styleClass="input-field"/>
                <Label fx:id="step3Status" styleClass="error-label"/>
                <Button text="Reset Password" onAction="#handleResetPassword" styleClass="submit-button"/>
                <Button text="Back" onAction="#handleBack" styleClass="back-button"/>
            </VBox>

        </VBox>
    </HBox>
</StackPane>
