<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?> 

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.DashboardController"
            prefWidth="1000" prefHeight="700">

    <!-- Top Bar -->
    <top>
        <ToolBar>
            <Label text="Freelance Business Manager" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS" />
            <Button text="Logout" onAction="#handleLogout"/>
        </ToolBar>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button fx:id="btnClients" text="Clients" onAction="#openClients" />
            <Button fx:id="btnFinance" text="Finance" onAction="#openFinance" />
            <Button fx:id="btnCommissions" text="Commissions" onAction="#openCommissions" />
        </VBox>
    </left>

    <!-- Center content -->
    <center>
        <StackPane fx:id="contentArea" alignment="CENTER">
            <Label text="Welcome to your dashboard!" style="-fx-font-size: 16px;"/>
        </StackPane>
    </center>
</BorderPane>
