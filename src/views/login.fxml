<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="liquidPane"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.LoginController"
           stylesheets="@login.css"
           prefWidth="950" prefHeight="600">

    <!-- Animated Background -->
    <Rectangle fx:id="liquidBackground"
               width="950" height="600"
               styleClass="animated-background"/> 

    <!-- Liquid glow that follows the mouse -->
    <Circle fx:id="oilGlow"
            radius="150"
            fill="linear-gradient(to bottom right, rgba(0,183,255,0.25), rgba(151,71,255,0.25))"
            opacity="0"/>

    <!-- Overlay for contrast -->
    <Rectangle fx:id="liquidOverlay"
               width="950" height="600"
               fill="rgba(0,0,0,0.3)"/>

    <!-- Form layout -->
    <HBox alignment="CENTER_RIGHT" spacing="0" prefWidth="950" prefHeight="600">

        <VBox fx:id="formBox"
              alignment="CENTER"
              spacing="15"
              styleClass="form-container"
              prefWidth="350"
              maxWidth="350">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40" />
            </padding>

            <Label text="Login" styleClass="form-title"/>

            <TextField fx:id="usernameField" promptText="Username" styleClass="input-field"/>
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>
            <Label fx:id="errorLabel" textFill="red" style="-fx-font-size: 13px;"/>

            <Button text="Login" onAction="#handleLogin" styleClass="register-button"/>

            <HBox alignment="CENTER" spacing="12">
                <Button text="Register" onAction="#handleRegister" styleClass="file-button"/>
                <Button text="Forgot Password" onAction="#handleForgotPassword" styleClass="back-button"/>
            </HBox>

            <Button text="🌙 Toggle Theme" onAction="#toggleTheme" styleClass="theme-toggle"/>
        </VBox>

        <Region prefWidth="50"/>
    </HBox>
</StackPane>
