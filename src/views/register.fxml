<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane fx:id="liquidPane"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.RegisterController"
           alignment="CENTER"
           prefWidth="900" prefHeight="600"
           stylesheets="@css/register.css">
  <!-- Liquid Background -->
  <Rectangle fx:id="liquidBackground" width="900" height="600"/>
  <!-- Iridescent Glow -->
  <Circle fx:id="oilGlow"
              radius="150"
              fill="radial-gradient(center 50% 50%, radius 50%, rgba(255,255,255,0.3), rgba(255,255,255,0))"
              opacity="0.0"/>
  <!-- Main Registration Form -->
  <VBox fx:id="formContainer"
            alignment="CENTER"
            spacing="20"
            styleClass="form-container"
            prefWidth="420"
            maxWidth="420">
    <Label fx:id="formTitle" text="Register Accrount" styleClass="form-title"/>
    <StackPane fx:id="contentPane" alignment="CENTER" prefWidth="380" prefHeight="380">
      <!-- Step 1 -->
      <VBox fx:id="step1Box" alignment="CENTER" spacing="20">
        <HBox alignment="CENTER" spacing="20">
          <RadioButton fx:id="clientRadio" text="Client" styleClass="radio-btn"/>
          <RadioButton fx:id="commissionerRadio" text="Commissioner" styleClass="radio-btn"/>
        </HBox>
        <Label fx:id="errorLabel" textFill="red" visible="false"/>
        <Button text="Next" onAction="#goToStep2" styleClass="register-button"/>
      </VBox>
      <!-- Step 2 -->
      <VBox fx:id="step2Box" alignment="CENTER" spacing="15" visible="false" managed="false">
        <TextField fx:id="usernameField" promptText="Username" styleClass="input-field"/>
        <TextField fx:id="phoneField" promptText="Phone Number" styleClass="input-field"/>
        <TextField fx:id="emailField" promptText="Email" styleClass="input-field"/>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" styleClass="input-field"/>
        <ComboBox fx:id="securityQuestionBox" promptText="Security Question" styleClass="input-field"/>
        <TextField fx:id="securityAnswerField" promptText="Answer" styleClass="input-field"/>
        <DatePicker fx:id="birthdayPicker" promptText="Birthday"/>
        <Label fx:id="ageWarningLabel" textFill="red" visible="false"/>
        <Button text="Next (Verify OTP)" onAction="#validateStep2ThenGoToOTP" styleClass="register-button"/>
        <Button text="Back" onAction="#backToStep1" styleClass="back-button"/>
      </VBox>
      <!-- Step 3 -->
      <VBox fx:id="otpBox" alignment="CENTER" spacing="15" visible="false" managed="false">
        <TextField fx:id="otpField" promptText="Enter OTP" styleClass="input-field"/>
        <Label fx:id="otpStatusLabel" textFill="green"/>
        <Button text="Verify OTP" onAction="#handleVerifyOTP" styleClass="register-button"/>
        <Button text="Back" onAction="#backToStep2" styleClass="back-button"/>
      </VBox>
      <!-- Step 4 -->
      <VBox fx:id="idUploadBox" alignment="CENTER" spacing="15" visible="false" managed="false">
        <Button fx:id="uploadIdButton" text="Upload Valid ID" onAction="#handleUploadID" styleClass="file-button"/>
        <Label fx:id="idStatusLabel" textFill="green"/>
        <Button text="Complete Registration" onAction="#completeRegistration" styleClass="register-button"/>
        <Button text="Back" onAction="#backToOTP" styleClass="back-button"/>
      </VBox>
    </StackPane>
    <Label fx:id="statusLabel" textFill="green"/>
  </VBox>
</StackPane>
